# ─── Required ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
OWNER_TELEGRAM_ID=            # Your Telegram numeric ID (from @userinfobot)

# ─── Token Rewards ───────────────────────────────────────
# Wallet that sends token rewards to users
REWARD_WALLET_PRIVATE_KEY=    # Private key (keep secret!)
REWARD_WALLET_ADDRESS=        # Corresponding wallet address

# ─── Subscription Payments ───────────────────────────────
# Treasury wallet that receives subscription payments
PAYMENT_ADDRESS=              # Your treasury wallet on Base
BASESCAN_API_KEY=             # From basescan.org/myapikey (free)

# ─── AI Features (optional) ──────────────────────────────
BANKR_LLM_KEY=                # From bankr.bot (for AI chat features)
BANKR_API_KEY=                # From bankr.bot (for trading features)

# ─── Optional ────────────────────────────────────────────
TALENT_API_KEY=               # From talentprotocol.com (for Builder Score)
NEYNAR_API_KEY=               # From neynar.com (for Farcaster features)
